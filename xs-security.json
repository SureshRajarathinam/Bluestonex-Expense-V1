{
  "xsappname": "expense-management",
  "tenant-mode": "dedicated",
  "description": "BluestoneX Expense Reimbursement System",
  "scopes": [
    {
      "name": "$XSAPPNAME.Employee",
      "description": "Submit and track own expense claims"
    },
    {
      "name": "$XSAPPNAME.Approver",
      "description": "Approve or reject expense claims (level 1 / level 2)"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Administer policy configuration and approval workflow members"
    }
  ],
  "attributes": [],
  "role-templates": [
    {
      "name": "Employee",
      "description": "Employee — submit and track own claims",
      "scope-references": [
        "$XSAPPNAME.Employee"
      ]
    },
    {
      "name": "Approver",
      "description": "Approver — approve/reject claims",
      "scope-references": [
        "$XSAPPNAME.Approver",
        "$XSAPPNAME.Employee"
      ]
    },
    {
      "name": "Admin",
      "description": "Administrator — policy & workflow configuration",
      "scope-references": [
        "$XSAPPNAME.Admin",
        "$XSAPPNAME.Employee"
      ]
    }
  ],
  "role-collections": [
    {
      "name": "Expense_Employee",
      "description": "BluestoneX Expense — Employee",
      "role-template-references": [
        "$XSAPPNAME.Employee"
      ]
    },
    {
      "name": "Expense_Approver",
      "description": "BluestoneX Expense — Approver",
      "role-template-references": [
        "$XSAPPNAME.Approver"
      ]
    },
    {
      "name": "Expense_Admin",
      "description": "BluestoneX Expense — Administrator",
      "role-template-references": [
        "$XSAPPNAME.Admin"
      ]
    }
  ]
}
