{
  "_version": "1.59.0",
  "sap.app": {
    "id": "com.bluestonex.expense.financeexpenses",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "1.0.0" },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "/finance/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.fiori": {
    "registrationIds": ["F-BSX-EXPENSE-FINANCE"],
    "archeType": "transactional"
  },
  "sap.cloud.service": "com.bluestonex.expense",
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m":            {},
        "sap.ui.core":      {},
        "sap.ushell":       {},
        "sap.fe.templates": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.bluestonex.expense.financeexpenses.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "FinanceClaimsList",
          "target": "FinanceClaimsList"
        },
        {
          "pattern": "FinanceClaims({key}):?query:",
          "name": "FinanceClaimsObjectPage",
          "target": "FinanceClaimsObjectPage"
        },
        {
          "pattern": "FinanceClaims({key})/items({key2}):?query:",
          "name": "FinanceClaimItemsObjectPage",
          "target": "FinanceClaimItemsObjectPage"
        }
      ],
      "targets": {
        "FinanceClaimsList": {
          "type": "Component",
          "id": "FinanceClaimsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "FinanceClaims",
              "variantManagement": "Page",
              "initialLoad": "Enabled",
              "navigation": {
                "FinanceClaims": {
                  "detail": { "route": "FinanceClaimsObjectPage" }
                }
              }
            }
          }
        },
        "FinanceClaimsObjectPage": {
          "type": "Component",
          "id": "FinanceClaimsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "FinanceClaims",
              "editableHeaderContent": false,
              "navigation": {
                "items": {
                  "detail": { "route": "FinanceClaimItemsObjectPage" }
                }
              }
            }
          }
        },
        "FinanceClaimItemsObjectPage": {
          "type": "Component",
          "id": "FinanceClaimItemsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "FinanceClaimItems",
              "editableHeaderContent": false
            }
          }
        }
      }
    }
  }
}
