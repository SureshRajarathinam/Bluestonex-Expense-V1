<mvc:View
  controllerName="com.bluestonex.expense.approval.controller.History"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout"
  height="100%">

  <ScrollContainer height="100%" vertical="true" horizontal="false">

    <!-- Look up (filters) -->
    <VBox class="bsxCard bsxPremiumCard">
      <Title text="{i18n>lookUp}" class="bsxCardTitle bsxCardPad" level="H3" />
      <l:Grid defaultSpan="XL3 L3 M6 S12" hSpacing="1" vSpacing="0" class="bsxCardPad">
        <VBox>
          <Label text="{i18n>colStatus}" class="bsxFieldLbl" />
          <Select id="fStatus" width="100%">
            <core:Item key="" text="{i18n>all}" />
            <core:Item key="Submitted" text="Submitted" />
            <core:Item key="FirstApproved" text="First Approved" />
            <core:Item key="Approved" text="Approved" />
            <core:Item key="Rejected" text="Rejected" />
          </Select>
        </VBox>
        <VBox>
          <Label text="{i18n>filterCountry}" class="bsxFieldLbl" />
          <Select id="fCountry" width="100%">
            <core:Item key="" text="{i18n>all}" />
            <core:Item key="UK" text="United Kingdom" />
            <core:Item key="IN" text="India" />
          </Select>
        </VBox>
        <VBox>
          <Label text="{i18n>colPeriod}" class="bsxFieldLbl" />
          <DateRangeSelection id="fPeriod" width="100%" />
        </VBox>
        <VBox>
          <Label text="{i18n>searchClaim}" class="bsxFieldLbl" />
          <Input id="fClaimNo" width="100%" placeholder="{i18n>searchClaim}" submit=".onGo" />
        </VBox>
        <VBox justifyContent="End">
          <Label text=" " />
          <Button text="{i18n>btnGo}" type="Emphasized" icon="sap-icon://search" press=".onGo" />
        </VBox>
      </l:Grid>
    </VBox>

    <!-- Results -->
    <VBox class="bsxCard bsxPremiumCard">
      <OverflowToolbar class="bsxCardPad">
        <Title text="{i18n>historyTitle}" class="bsxCardTitle" level="H3" />
        <ObjectStatus class="sapUiTinyMarginBegin" inverted="true" state="Information" text="{= ${i18n>kpiTotal} + ': ' + ${view>/count} }" />
        <ObjectStatus inverted="true" state="Success" text="{= ${i18n>kpiApproved} + ': ' + ${view>/approved} }" />
        <ObjectStatus inverted="true" state="Error" text="{= 'Rejected: ' + ${view>/rejected} }" />
        <ToolbarSpacer />
        <Button text="{i18n>btnExport}" icon="sap-icon://pdf-attachment" type="Transparent" tooltip="{i18n>btnExport}" press=".onExportPdf" />
        <Button text="{i18n>btnRefresh}" icon="sap-icon://refresh" type="Transparent" press=".onRefresh" />
      </OverflowToolbar>

      <Table
        id="historyTable"
        class="bsxTable"
        growing="true"
        growingThreshold="50"
        items="{ path: '/ClaimHistory', parameters: { '$count': true } }"
        updateFinished=".onUpdateFinished"
        mode="None">
        <noData>
          <IllustratedMessage illustrationType="sapIllus-NoEntries" title="{i18n>noHistory}" />
        </noData>
        <columns>
          <Column><Text text="{i18n>colClaimNo}" /></Column>
          <Column><Text text="{i18n>colEmployee}" /></Column>
          <Column><Text text="{i18n>colCountry}" /></Column>
          <Column><Text text="{i18n>colPeriod}" /></Column>
          <Column><Text text="{i18n>colStatus}" /></Column>
          <Column hAlign="End"><Text text="{i18n>colTotal}" /></Column>
          <Column><Text text="{i18n>colSubmittedOn}" /></Column>
          <Column><Text text="{i18n>colDecidedBy}" /></Column>
        </columns>
        <items>
          <ColumnListItem>
            <cells>
              <ObjectIdentifier title="{claimNumber}" />
              <Text text="{employeeName}" />
              <Text text="{path: 'country', formatter: '.formatter.countryText'}" />
              <Text text="{= ${claimPeriod} + (${periodEnd} ? ' – ' + ${periodEnd} : '') }" />
              <ObjectStatus
                icon="{path: 'status', formatter: '.formatter.statusIcon'}"
                text="{path: 'status', formatter: '.formatter.statusText'}"
                state="{path: 'statusCriticality', formatter: '.formatter.statusState'}" />
              <ObjectNumber number="{ parts: ['totalGross','currency'], formatter: '.formatter.money' }" />
              <Text text="{submittedAt}" />
              <Text text="{= ${level2ApprovedBy} || ${level1ApprovedBy} || ${rejectedBy} || '—' }" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </VBox>
  </ScrollContainer>
</mvc:View>
