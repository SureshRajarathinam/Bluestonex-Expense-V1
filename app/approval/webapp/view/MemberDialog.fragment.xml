<core:FragmentDefinition
  xmlns:core="sap.ui.core"
  xmlns="sap.m"
  xmlns:f="sap.ui.layout.form">

  <Dialog id="memberDialog" title="{i18n>tabWorkflow}" contentWidth="30rem">
    <content>
      <f:SimpleForm editable="true" layout="ResponsiveGridLayout" columnsM="1" columnsL="1">
        <f:content>
          <Label text="{i18n>colWfCountry}" />
          <Text text="{countryName} ({country})" />
          <Label text="{i18n>colFirst}" required="true" />
          <Input value="{firstApprover}" type="Email" placeholder="first.approver@bluestonex.com" />
          <Label text="{i18n>colSecond}" />
          <Input value="{secondApprover}" type="Email" placeholder="second.approver@bluestonex.com"
            editable="{ path: 'country', formatter: '.formatter.isUK', targetType: 'any' }" />
        </f:content>
      </f:SimpleForm>
      <Text text="{i18n>wfHint}" class="sapUiSmallMargin" />
    </content>
    <buttons>
      <Button text="{i18n>btnSave}" type="Emphasized" class="bsxPill" press=".onSaveMember" />
      <Button text="{i18n>btnCancel}" class="bsxPill" press=".onCancelMember" />
    </buttons>
  </Dialog>
</core:FragmentDefinition>
