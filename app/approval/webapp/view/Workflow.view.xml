<mvc:View
  controllerName="com.bluestonex.expense.approval.controller.Workflow"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  height="100%">

  <!-- ══ CHOOSE MODE — pick the country whose approvers to manage ═════════ -->
  <VBox class="bsxCard" visible="{ui>/choose}">
    <OverflowToolbar class="bsxCardPad">
      <Title text="{i18n>workflowTitle}" class="bsxCardTitle" level="H3" />
      <ToolbarSpacer />
      <Button text="{i18n>btnRefresh}" icon="sap-icon://refresh" type="Transparent" press=".onRefresh" />
    </OverflowToolbar>
    <Text text="{i18n>wfHint}" class="bsxCardPad bsxFieldLbl" />

    <FlexBox wrap="Wrap" class="bsxCardPad">
      <!-- United Kingdom -->
      <VBox class="bsxCard bsxPremiumCard bsxChoiceCard sapUiMediumMarginEnd sapUiMediumMarginBottom" width="24rem">
        <HBox class="bsxCardPad" alignItems="Center">
          <Avatar initials="UK" displayShape="Square" backgroundColor="Accent6" class="sapUiSmallMarginEnd" />
          <VBox>
            <Title text="{i18n>countryUKName}" level="H4" class="bsxCardTitle" />
            <Text text="{i18n>wfUKSub}" class="bsxFieldLbl" />
          </VBox>
        </HBox>
        <HBox class="bsxCardPad" alignItems="Center" justifyContent="SpaceBetween">
          <Text text="{i18n>chainTwoLevel}" class="bsxCardTag" />
          <Button text="{i18n>btnManage}" type="Emphasized" icon="sap-icon://manager" class="bsxPill bsxCardPill" press=".onChooseUK" />
        </HBox>
      </VBox>

      <!-- India -->
      <VBox class="bsxCard bsxPremiumCard bsxChoiceCard sapUiMediumMarginEnd sapUiMediumMarginBottom" width="24rem">
        <HBox class="bsxCardPad" alignItems="Center">
          <Avatar initials="IN" displayShape="Square" backgroundColor="Accent8" class="sapUiSmallMarginEnd" />
          <VBox>
            <Title text="{i18n>countryINName}" level="H4" class="bsxCardTitle" />
            <Text text="{i18n>wfINSub}" class="bsxFieldLbl" />
          </VBox>
        </HBox>
        <HBox class="bsxCardPad" alignItems="Center" justifyContent="SpaceBetween">
          <Text text="{i18n>chainSingleLevel}" class="bsxCardTag" />
          <Button text="{i18n>btnManage}" type="Emphasized" icon="sap-icon://manager" class="bsxPill bsxCardPill" press=".onChooseIN" />
        </HBox>
      </VBox>
    </FlexBox>
  </VBox>

  <!-- ══ DETAIL MODE — the selected country's approval chain ══════════════ -->
  <VBox class="bsxCard bsxPremiumCard" visible="{ui>/detail}">
    <OverflowToolbar class="bsxCardPad">
      <Button icon="sap-icon://nav-back" type="Transparent" tooltip="{i18n>btnBack}" press=".onBack" />
      <Title text="{ui>/title}" class="bsxCardTitle" level="H3" />
      <ToolbarSpacer />
    </OverflowToolbar>

    <!-- bound in the controller to the chosen country's wf>/rows row -->
    <VBox id="wfDetail" class="bsxCardPad sapUiSmallMarginBottom">

      <!-- DISPLAY mode -->
      <VBox visible="{= !${wf>editing} }">
        <HBox class="bsxWfRow" alignItems="Center">
          <Text text="1" class="bsxChainNode" />
          <Avatar initials="{wf>firstInitials}" displaySize="S" class="sapUiSmallMarginBegin" />
          <VBox class="sapUiMediumMarginBegin" width="100%">
            <Label text="{i18n>firstLevelApprover}" design="Bold" />
            <Text text="{wf>firstName}" />
            <Text text="{wf>firstApprover}" class="bsxFieldLbl" />
          </VBox>
          <ObjectStatus text="{i18n>lvlOne}" state="Information" inverted="true" />
        </HBox>

        <HBox class="bsxChainConnector" visible="{wf>twoLevel}" />
        <HBox class="bsxWfRow" alignItems="Center" visible="{wf>twoLevel}">
          <Text text="2" class="bsxChainNode" />
          <Avatar initials="{wf>secondInitials}" displaySize="S" class="sapUiSmallMarginBegin" />
          <VBox class="sapUiMediumMarginBegin" width="100%">
            <Label text="{i18n>secondLevelApprover}" design="Bold" />
            <Text text="{wf>secondName}" />
            <Text text="{wf>secondApprover}" class="bsxFieldLbl" />
          </VBox>
          <ObjectStatus text="{i18n>lvlTwo}" state="Success" inverted="true" />
        </HBox>

        <MessageStrip
          text="{i18n>singleLevelNote}"
          type="Information"
          showIcon="true"
          class="sapUiMediumMarginTop"
          visible="{= !${wf>twoLevel} }" />

        <OverflowToolbar class="sapUiMediumMarginTop">
          <ToolbarSpacer />
          <Button text="{i18n>btnEdit}" icon="sap-icon://edit" type="Emphasized" class="bsxPill" press=".onEditCard" />
        </OverflowToolbar>
      </VBox>

      <!-- EDIT mode -->
      <VBox visible="{wf>editing}">
        <Label text="{i18n>firstLevelApprover}" required="true" />
        <ComboBox
          selectedKey="{wf>firstApprover}"
          items="{ path: 'wf>/employees', templateShareable: false }"
          width="100%"
          placeholder="{i18n>selectApprover}">
          <core:ListItem key="{wf>email}" text="{wf>fullName} ({wf>email})" />
        </ComboBox>
        <Label text="{i18n>secondLevelApprover}" required="true" visible="{wf>twoLevel}" class="sapUiMediumMarginTop" />
        <ComboBox
          selectedKey="{wf>secondApprover}"
          items="{ path: 'wf>/employees', templateShareable: false }"
          width="100%"
          visible="{wf>twoLevel}"
          placeholder="{i18n>selectApprover}">
          <core:ListItem key="{wf>email}" text="{wf>fullName} ({wf>email})" />
        </ComboBox>

        <OverflowToolbar class="sapUiMediumMarginTop">
          <ToolbarSpacer />
          <Button text="{i18n>btnCancel}" type="Transparent" press=".onCancelCard" />
          <Button text="{i18n>btnSave}" type="Emphasized" class="bsxPill" press=".onSaveCard" />
        </OverflowToolbar>
      </VBox>

    </VBox>
  </VBox>
</mvc:View>
