{
  "_version": "1.59.0",
  "sap.app": {
    "id": "com.bluestonex.expense.workflowmembers",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "1.0.0" },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": { "uri": "/approval/", "type": "OData", "settings": { "odataVersion": "4.0" } }
    }
  },
  "sap.ui": { "technology": "UI5", "deviceTypes": { "desktop": true, "tablet": true, "phone": true } },
  "sap.fiori": { "registrationIds": ["F-BSX-EXPENSE-WORKFLOW"], "archeType": "transactional" },
  "sap.cloud.service": "com.bluestonex.expense",
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": { "sap.m": {}, "sap.ui.core": {}, "sap.ushell": {}, "sap.fe.templates": {} }
    },
    "models": {
      "i18n": { "type": "sap.ui.model.resource.ResourceModel", "settings": { "bundleName": "com.bluestonex.expense.workflowmembers.i18n.i18n" } },
      "": { "dataSource": "mainService", "preload": true, "settings": { "operationMode": "Server", "autoExpandSelect": true, "earlyRequests": true } }
    },
    "routing": {
      "config": {},
      "routes": [
        { "pattern": ":?query:", "name": "WorkflowList", "target": "WorkflowList" },
        { "pattern": "WorkflowMembers({key}):?query:", "name": "WorkflowObjectPage", "target": "WorkflowObjectPage" }
      ],
      "targets": {
        "WorkflowList": {
          "type": "Component", "id": "WorkflowList", "name": "sap.fe.templates.ListReport",
          "options": { "settings": { "entitySet": "WorkflowMembers", "variantManagement": "Page", "initialLoad": "Enabled",
            "navigation": { "WorkflowMembers": { "detail": { "route": "WorkflowObjectPage" } } } } }
        },
        "WorkflowObjectPage": {
          "type": "Component", "id": "WorkflowObjectPage", "name": "sap.fe.templates.ObjectPage",
          "options": { "settings": { "entitySet": "WorkflowMembers", "editableHeaderContent": false } }
        }
      }
    }
  }
}
